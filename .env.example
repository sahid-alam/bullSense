LLM_JUDGMENT_MODEL=claude-sonnet-5

# ===== storage =====
DATABASE_URL=placeholder           # Supabase Postgres connection string (Project Settings → Database → URI)
                                   # state: signals, receipts, positions — browsable in the Supabase dashboard
R2_ACCOUNT_ID=placeholder          # Cloudflare R2 (free 10GB) — bulk price history as parquet
R2_ACCESS_KEY_ID=placeholder
R2_SECRET_ACCESS_KEY=placeholder
R2_BUCKET=bullsense-history

# ===== interface =====
TELEGRAM_BOT_TOKEN=placeholder     # @BotFather /newbot — needed by week 3 (first briefing)
DATABASE_CA_CERT=                  # optional: Supabase CA cert (Project Settings → Database → SSL) for direct connections; pooler endpoints verify against system roots
