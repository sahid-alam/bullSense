# ============================================================
# REQUIRED — the pipeline does not run without these
# ============================================================

# --- storage: Supabase (Project Settings → API) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=placeholder    # the "secret"/service key — only way past RLS besides direct pg
# SUPABASE_DB_URL is auto-injected into the edge function by Supabase — do NOT set it here.

# --- intelligence: Groq (free, OpenAI-compatible) covers BOTH tiers ---
GROQ_API_KEY=placeholder           # console.groq.com — free tier
GROQ_ROUTINE_MODEL=llama-3.3-70b-versatile
LLM_ROUTINE_MODEL=claude-haiku-4-5-20251001   # only used if ANTHROPIC_API_KEY is set
LLM_JUDGMENT_MODEL=claude-sonnet-5            # only used if ANTHROPIC_API_KEY is set

# --- interface: Telegram (@BotFather /newbot) ---
TELEGRAM_BOT_TOKEN=placeholder

# ============================================================
# OPTIONAL — improves quality, costs money, safe to skip
# ============================================================

ANTHROPIC_API_KEY=placeholder      # upgrades judgment tier (theses/debates) from Groq gpt-oss to Claude Sonnet.
                                   # Without it, judgment falls back to Groq automatically. Add when you want the quality.

