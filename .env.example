# ============================================================
#  BullSense — environment reference
#  Copy this file to `.env` and fill in the REQUIRED values.
#  Anything marked "no key" is already wired and needs NOTHING here.
# ============================================================


# ------------------------------------------------------------
#  MARKET DATA — where the stock stats come from
#  These are all FREE and need NO API key. Listed here only so
#  you know what feeds the engine. Do NOT add keys for these.
# ------------------------------------------------------------
#   • Prices / OHLC / VIX / ETFs .... Yahoo Finance chart API   (no key)
#   • Short interest ................ FINRA Consolidated SI API  (no key)
#   • Fundamentals / filings ........ SEC EDGAR                 (no key)
#   • Retail sentiment .............. ApeWisdom + Tradestie     (no key)
#   • India: NSE bhavcopy + delivery % + FII/DII .. nseindia.com (no key)
#   • India VIX / NIFTY ............. Yahoo (^INDIAVIX / ^NSEI)  (no key)
#
#  => There is nothing to buy or paste for stock-market stats.
#     The engine already pulls all of it for free.


# ============================================================
#  REQUIRED — the pipeline does not run without these
# ============================================================

# --- Storage: Supabase (Project Settings → API) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SECRET_KEY=placeholder    # the "secret"/service key — the only way past RLS besides direct Postgres
# SUPABASE_DB_URL is auto-injected into the edge function by Supabase — do NOT set it here.

# --- Intelligence: Groq (FREE, OpenAI-compatible) — the brain that writes analysis ---
GROQ_API_KEY=placeholder                       # console.groq.com — free tier, covers both thinking tiers
GROQ_ROUTINE_MODEL=llama-3.3-70b-versatile     # fast/cheap tier (daily narratives)
GROQ_JUDGMENT_MODEL=llama-3.3-70b-versatile    # deep tier (dossiers, debates)

# --- Interface: Telegram (@BotFather → /newbot) — how you talk to the analyst ---
TELEGRAM_BOT_TOKEN=placeholder


# ============================================================
#  OPTIONAL — improves quality, costs money, safe to skip
# ============================================================

ANTHROPIC_API_KEY=placeholder                  # upgrades the "judgment" tier from Groq to Claude.
                                               # Without it, judgment stays on Groq automatically.
LLM_ROUTINE_MODEL=claude-haiku-4-5-20251001    # only used if ANTHROPIC_API_KEY is set
LLM_JUDGMENT_MODEL=claude-sonnet-5             # only used if ANTHROPIC_API_KEY is set


# ============================================================
#  FUTURE — no code reads these yet; add the day the feature lands
# ============================================================

# FMP_API_KEY=placeholder          # paid price data; currently on free Yahoo. Wire into providers/prices.ts first.
# SENTIMENT_API_KEY=placeholder    # paid sentiment vendor; currently ApeWisdom/Tradestie free.
# ALPACA_API_KEY=placeholder       # paper trading / execution path — not built yet.
# ALPACA_SECRET=placeholder
# R2_ACCOUNT_ID=placeholder        # Cloudflare R2 bulk price-history archive — archiver not built yet.
# R2_ACCESS_KEY_ID=placeholder
# R2_SECRET_ACCESS_KEY=placeholder
# R2_BUCKET=bullsense-history
